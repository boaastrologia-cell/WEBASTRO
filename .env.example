# ODISSEU AGENTE IA - Configurações

# Ambiente
ENVIRONMENT=development
DEBUG=True

# Odisseu Configuration
ODISSEU_API_KEY=your_odisseu_api_key_here
ODISSEU_ENDPOINT=http://localhost:8000
ODISSEU_TIMEOUT=30

# Web Server
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
FLASK_DEBUG=True

# Database (se necessário)
DATABASE_URL=sqlite:///webastro.db
DATABASE_POOL_SIZE=10

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/webastro.log

# Astronomy
TIMEZONE=America/Sao_Paulo
LATITUDE=-15.8267
LONGITUDE=-47.8822

# Security
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# API Keys (se necessário integração com APIs externas)
OPENAI_API_KEY=
NASA_API_KEY=

# Features
ENABLE_CACHE=True
CACHE_TTL=3600
